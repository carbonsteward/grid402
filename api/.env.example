# ---- Grid402 API config ----

# Port for the Hono server
PORT=3402

# Your payee EVM address on Base (where USDC settles)
# Get a wallet via https://docs.cdp.coinbase.com/cdp-api/docs/welcome
# Or use any EVM wallet (Privy, Rainbow, MetaMask, etc.)
EVM_ADDRESS=0xYourBaseAddressHere

# x402 facilitator URL
# Use the Coinbase CDP-hosted facilitator for Base + Base Sepolia
#   Mainnet:  https://x402.org/facilitator
#   Testnet:  https://x402.org/facilitator (auto-routes by network)
# Other options: https://www.x402.org/ecosystem?category=facilitators
FACILITATOR_URL=https://x402.org/facilitator

# Which network to accept payment on
# eip155:8453    -> Base mainnet       (real USDC)
# eip155:84532   -> Base Sepolia       (testnet USDC, free from faucets)
# Start with Sepolia for hackathon demos
PAYMENT_NETWORK=eip155:84532

# ---- Optional: caching layer ----
# Leave empty to use in-memory cache
CACHE_URL=
