---
import Layout from "../../layouts/Layout.astro";
const docs = [
  { slug: "quickstart", title: "Quickstart", desc: "Make your first paid call in 60 seconds — starts with /mix, the primary signal." },
  { slug: "endpoints",  title: "Endpoints",  desc: "All routes — mix (primary), emissions (derived), spot price (bundled), combined." },
  { slug: "x402",       title: "x402 protocol", desc: "How HTTP 402 + USDC on Base settles each call." },
  { slug: "isos",       title: "Grid operator coverage", desc: "CAISO, ERCOT, NESO (GB), KPX, AEMO — Independent System Operators (not the standards body). Granularity, freshness, source URLs." },
];
---
<Layout title="Docs · Grid402">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-accent-mint)] font-semibold mb-3">Documentation</p>
    <h1 class="text-4xl font-bold mb-4">Time your agents with Grid402</h1>
    <p class="text-[var(--color-text-muted)] mb-8 max-w-2xl">
      Grid402 is an HTTP API for the world's electricity grid. Every request to a paid endpoint returns
      <code class="font-mono text-[var(--color-accent-warm)] bg-[rgba(255,255,255,0.05)] px-1 py-0.5 rounded">402 Payment Required</code> until you attach a signed
      x402 payload. Free routes (health, schema, demo-tier mix) work without payment.
    </p>

    <div class="rounded-xl border border-[var(--color-grid-stroke)] bg-[rgba(0,188,188,0.04)] p-5 mb-10">
      <p class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-accent-primary)] font-semibold mb-3">
        Primary product
      </p>
      <p class="text-base mb-2"><strong class="text-[var(--color-text-light)]">5-minute generation mix and the carbon intensity computed from it.</strong></p>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
        Hourly mix is commoditized. Sub-hourly mix is what makes 24/7 CFE verification, hourly CBAM reporting, and DePIN
        slashing computationally possible — and it's what no other vendor sells per-call. Spot price is shipped alongside,
        but the moat is the mix.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-3">
      {docs.map(d => (
        <a href={`/docs/${d.slug}`} class="block rounded-lg border border-[var(--color-grid-stroke)] p-5 hover:border-[var(--color-accent-mint)] transition-colors">
          <h2 class="font-semibold text-lg mb-1">{d.title}</h2>
          <p class="text-sm text-[var(--color-text-muted)]">{d.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
