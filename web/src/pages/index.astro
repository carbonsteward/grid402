---
import Layout from "../layouts/Layout.astro";
import WorldMap from "../components/WorldMap";
---
<Layout>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-12">
    <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-accent-primary)] font-semibold mb-3">
      Pay-per-call · USDC on Base · x402
    </p>
    <h1 class="text-5xl md:text-6xl font-bold leading-tight tracking-tight">
      The world's electricity grid,<br />
      <span class="text-[var(--color-accent-primary)]">priced by the call.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--color-text-muted)] leading-relaxed">
      Sub-hourly generation mix, spot prices, and emissions for every major ISO.
      No API key. No subscription. Pay for what you query — settled on-chain in USDC.
    </p>

    <div class="mt-8 flex flex-wrap gap-3 text-sm">
      <a href="/docs/quickstart" class="px-5 py-2.5 rounded-md bg-[var(--color-accent-primary)] text-[var(--color-slide-bg)] font-semibold hover:opacity-90">
        Quickstart →
      </a>
      <a href="/docs/endpoints" class="px-5 py-2.5 rounded-md border border-[var(--color-grid-stroke)] hover:border-[var(--color-accent-mint)]">
        Endpoints
      </a>
      <a href="/docs/x402" class="px-5 py-2.5 rounded-md border border-[var(--color-grid-stroke)] hover:border-[var(--color-accent-mint)]">
        How x402 works
      </a>
    </div>
  </section>

  <section class="max-w-[1400px] mx-auto px-6 pb-16">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold">Live carbon intensity</h2>
      <span class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">USA · UK · KOREA · AUSTRALIA</span>
    </div>
    <WorldMap client:load />
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="grid md:grid-cols-3 gap-4">
      <div class="rounded-lg border border-[var(--color-grid-stroke)] p-6">
        <h3 class="font-semibold text-lg mb-2">Sub-hourly mix</h3>
        <p class="text-sm text-[var(--color-text-muted)]">5-minute generation breakdown direct from each ISO. Most competitors report hourly aggregates with 15+ minute lag.</p>
      </div>
      <div class="rounded-lg border border-[var(--color-grid-stroke)] p-6">
        <h3 class="font-semibold text-lg mb-2">No API key</h3>
        <p class="text-sm text-[var(--color-text-muted)]">A wallet signature replaces signups, dashboards, billing portals. Hit the endpoint, sign a 402 challenge, get JSON.</p>
      </div>
      <div class="rounded-lg border border-[var(--color-grid-stroke)] p-6">
        <h3 class="font-semibold text-lg mb-2">Spot prices included</h3>
        <p class="text-sm text-[var(--color-text-muted)]">LMP (CAISO/ERCOT), SMP (KPX), RRP (AEMO). Carbon-aware compute meets price-aware load shifting.</p>
      </div>
    </div>
  </section>
</Layout>
