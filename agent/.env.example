# ---- Agent wallet (CDP-managed, Base Sepolia by default) ----
# Generate keys at https://portal.cdp.coinbase.com/
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret
CDP_WALLET_SECRET=your-cdp-wallet-secret

# Which network the agent wallet operates on
#   base-sepolia (testnet, free USDC from faucets)
#   base         (mainnet, real USDC)
NETWORK_ID=base-sepolia

# ---- LLM (OpenAI for the LangChain demo) ----
OPENAI_API_KEY=sk-your-openai-key-here

# ---- Grid402 endpoint the agent will call ----
# Local dev:    http://localhost:3402
# Deployed:     https://api.grid402.xyz (or your Cloudflare Worker URL)
GRID402_URL=http://localhost:3402

# Maximum USDC the agent will pay per x402 call (safety cap)
X402_MAX_PAYMENT_USDC=0.10
